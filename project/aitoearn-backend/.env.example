# --- 核心基础配置 ---
NODE_ENV=production
APP_DOMAIN=your-backend-domain.zeabur.app
JWT_SECRET=随便填一个长字符串
INTERNAL_TOKEN=随便填一个长字符串

# --- 数据库 (MongoDB Atlas) ---
# 直接填入您获取到的完整 URI
MONGODB_URI=mongodb+srv://marble109911_db_user:109911lZ@cluster0.egtyt9f.mongodb.net/?appName=Cluster0

# --- 缓存 (Upstash Redis) ---
REDIS_HOST=your-upstash-host
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password

# --- 服务间通信 ---
# 如果在 Zeabur 部署，可以填入服务的内网或外网地址
AI_URL=http://aitoearn-ai:3010
SERVER_URL=http://aitoearn-server:3002

# --- 对象存储 (默认配置) ---
ASSETS_CONFIG='{"provider":"s3","region":"us-east-1","bucketName":"aitoearn","endpoint":"http://rustfs.local:9000","publicEndpoint":"http://127.0.0.1:9000","accessKeyId":"rustfsadmin","secretAccessKey":"rustfsadmin","forcePathStyle":true}'
